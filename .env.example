# ITD5 Agentic Stack — Environment Variables
# Copy this file: cp .env.example .env
# Fill in your actual keys in .env (never commit .env)

# =============================================================
# REQUIRED: AI Provider Keys
# =============================================================

# Anthropic (Claude) — required for Claude Code + gstack
# Get yours: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================
# OPTIONAL: Additional AI Providers
# =============================================================

# OpenAI — optional, used by /codex skill for second opinions
OPENAI_API_KEY=sk-...

# =============================================================
# OPTIONAL: Database (Paperclip uses embedded Postgres by default)
# =============================================================

# Leave blank to use Paperclip's built-in embedded PostgreSQL
# Set this only if you want to use your own external Postgres
DATABASE_URL=
# Example: postgresql://user:password@localhost:5432/paperclip

# =============================================================
# OPTIONAL: Paperclip Ports
# =============================================================

PAPERCLIP_PORT=3100
PAPERCLIP_UI_PORT=3101

# =============================================================
# OPTIONAL: Telemetry (gstack)
# =============================================================

# gstack telemetry is OFF by default. Set to 'on' to opt in.
GSTACK_TELEMETRY=off

# =============================================================
# OPTIONAL: Supabase (if using Supabase for gstack analytics)
# =============================================================

SUPABASE_URL=
SUPABASE_ANON_KEY=

# =============================================================
# OPTIONAL: Tailscale (for mobile access)
# =============================================================
# After installing Tailscale, your Paperclip is accessible at:
# http://[your-tailscale-ip]:3100
# No additional config needed here — just install Tailscale.
